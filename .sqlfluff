# sqlfluff config for PuckBunny.
#
# We use the jinja templater (not dbt) so sqlfluff can run without a compiled
# dbt project. This handles `{{ ref('x') }}` and `{{ source('a', 'b') }}`
# syntactically without needing to actually resolve them. Upgrade to the dbt
# templater once we have macros or model-generation logic that benefits from
# full compilation.

[sqlfluff]
dialect = duckdb
templater = jinja
# Files that aren't SQL are ignored automatically. .sqlfluffignore adds more.
exclude_rules = none
max_line_length = 100

[sqlfluff:indentation]
tab_space_size = 2
indent_unit = space

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

# Case conventions: uppercase keywords, functions, types, and literals
# (SELECT, COUNT, INTEGER, TRUE/FALSE/NULL). User-defined identifiers —
# table and column names — stay lowercase snake_case.
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower
