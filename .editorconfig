root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md,sql}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # markdown uses trailing spaces for line breaks

[Makefile]
indent_style = tab
