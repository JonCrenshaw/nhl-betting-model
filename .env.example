# PuckBunny — local environment template.
#
# Copy to `.env` (gitignored) and fill in real values. See
# docs/milestones/m2-nhl-ingestion.md "Kickoff prerequisites" for the
# step-by-step on provisioning Cloudflare R2 credentials.
#
# Every variable here is read by puckbunny.config.Settings via
# pydantic-settings. Required values have no default; commented values
# show the production defaults if omitted.

# ---------- Cloudflare R2 (S3-compatible) ----------
# Required. The Account ID is the 32-char hex string visible top-right in
# the Cloudflare dashboard. The endpoint URL is of the form:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET=puckbunny-lake
R2_REGION=auto

# ---------- Ingestion defaults ----------
# Conservative posture per docs/milestones/m2-nhl-ingestion.md D6.
# Override at the CLI level when you need to throttle further.
INGEST_RATE_LIMIT_PER_SEC=2
INGEST_USER_AGENT=PuckBunny/0.1 (contact: you@example.com)
# INGEST_REQUEST_TIMEOUT_SECONDS=60
# INGEST_MAX_RETRIES=5
